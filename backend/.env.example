# Copy this file to .env and fill in your credentials.

# --- LLM providers (configure at least one; all have free tiers) ---
# Groq    — https://console.groq.com        (free: 1,000 req/day on llama-3.3-70b)
# Cerebras — https://cloud.cerebras.ai      (free: 1M tokens/day on gpt-oss-120b)
# Gemini  — https://aistudio.google.com     (free but low daily quota; also used for embeddings)
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=your_google_ai_studio_key_here   # required: embeddings use gemini-embedding-001

# --- Provider fallback chains (provider:model, comma-separated, tried in order) ---
# Providers without an API key are skipped automatically.
GENERATION_CHAIN=groq:llama-3.3-70b-versatile,cerebras:gpt-oss-120b,gemini:gemini-2.5-flash-lite
EXTRACTION_CHAIN=groq:llama-3.3-70b-versatile,cerebras:gpt-oss-120b,gemini:gemini-2.5-flash-lite

# --- Legacy model config (Playwright scraper path only) ---
SCRAPER_MODEL=gemini-2.5-flash-lite

# --- Supabase ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_DB_PASSWORD=        # only needed for scripts/migrate_phase3.py

# --- Phase 3: Web Search Agent ---
TAVILY_API_KEY=              # Get free at app.tavily.com (1000 req/month free)
CARD_CACHE_TTL_HOURS=24      # Re-search if regional data older than this

# --- Optional: Langfuse observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
