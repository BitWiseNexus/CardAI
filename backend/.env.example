# Copy this file to .env and fill in your credentials.

# --- Required ---
GEMINI_API_KEY=your_google_ai_studio_key_here

# --- Model selection (override if needed) ---
# Options confirmed working (non-thinking, free tier):
#   gemini-2.5-flash-lite   ← default, recommended
#   gemini-3.1-flash-lite   ← alternative
#   gemini-2.0-flash        ← high RPD but exhausts daily
GENERATION_MODEL=gemini-2.5-flash-lite
SCRAPER_MODEL=gemini-2.5-flash-lite
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Optional: Langfuse observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
 