# Copy this file to .env and fill in your credentials.

# --- LLM providers (configure at least one; all have free tiers) ---
# Groq     — https://console.groq.com     (free: ~1,000 req/day on llama-3.3-70b)
# Cerebras — https://cloud.cerebras.ai    (free: ~1M tokens/day on gpt-oss-120b)
# Gemini   — https://aistudio.google.com  (required: embeddings use gemini-embedding-001)
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=

# --- Provider fallback chains (provider:model, comma-separated, tried in order) ---
# Providers without an API key are skipped automatically. Defaults shown:
# GENERATION_CHAIN=groq:llama-3.3-70b-versatile,cerebras:gpt-oss-120b,gemini:gemini-2.5-flash-lite
# EXTRACTION_CHAIN=groq:llama-3.3-70b-versatile,cerebras:gpt-oss-120b,gemini:gemini-2.5-flash-lite

# --- Web search agent ---
TAVILY_API_KEY=              # free at app.tavily.com (1000 req/month)
CARD_CACHE_TTL_HOURS=24      # re-search if regional data older than this

# --- Supabase ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_DB_PASSWORD=        # only needed for scripts/migrate_phase3.py

# --- Production hardening ---
# Comma-separated browser origins allowed by CORS (set to your frontend URL in prod)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# When set, /api/ingest and /api/cache/clear require the X-Admin-Key header
ADMIN_API_KEY=

# --- Legacy static scraper (dev only, requires playwright) ---
SCRAPER_MODEL=gemini-2.5-flash-lite
